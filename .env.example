# Copy this file to ".env" and fill in your key, OR just paste the key
# into the Settings panel inside the app (the app writes it here for you).

# Your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Default model used to generate websites. You can change this in Settings.
# Examples: gemini-3.1-flash-lite, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Generation tuning (optional)
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_OUTPUT_TOKENS=32768

# Port the builder UI runs on
BUILDER_PORT=8000

# ===========================================================================
# Inbound-call agent (voice_agent.py) — only needed if you use the phone agent.
# Dial a Twilio number, say what to build, get the Vercel link on WhatsApp.
# (Gemini key + Vercel token are read from the builder's Settings, not here.)
# ===========================================================================

# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp sender. Default is Twilio's shared SANDBOX number.
# For the sandbox you must first text "join <your-code>" to +1 415 523 8886.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number in E.164 (e.g. +14085551234) to receive the link.
# If blank, the agent texts whichever number placed the call.
WHATSAPP_TO=

# Port the voice agent runs on (expose this with ngrok)
VOICE_AGENT_PORT=8001

# How long (seconds) to wait for the Vercel build before giving up
VOICE_DEPLOY_TIMEOUT=210

# ===========================================================================
# Full-duplex realtime agent (voice_realtime.py) — only if you want the
# natural, conversational version with a human-sounding voice + barge-in.
# Uses the Twilio/WhatsApp vars above PLUS:
# ===========================================================================

# Deepgram streaming speech-to-text (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# ElevenLabs text-to-speech (https://elevenlabs.io → Profile → API key)
ELEVEN_API_KEY=
# Voice to use. Defaults to a stock voice if left blank. Pick one in the
# ElevenLabs "Voices" library and copy its Voice ID.
ELEVEN_VOICE_ID=

# Public https URL the agent is reachable at (your ngrok URL). Optional —
# if blank, it's derived from the incoming request's host header.
PUBLIC_BASE_URL=

# Port the realtime agent runs on (expose this with ngrok)
VOICE_RT_PORT=8002

# Max conversation turns before it stops asking and just builds
VOICE_MAX_TURNS=4
