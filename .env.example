# Copy this file to ".env" and fill in your key, OR just paste the key
# into the Settings panel inside the app (the app writes it here for you).

# Your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Default model used to generate websites. You can change this in Settings.
# Examples: gemini-3.1-flash-lite, gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Generation tuning (optional)
GEMINI_TEMPERATURE=0.6
GEMINI_MAX_OUTPUT_TOKENS=32768

# Port the builder UI runs on
BUILDER_PORT=8000
